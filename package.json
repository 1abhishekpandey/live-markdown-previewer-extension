{
  "publisher": "1AbhishekPandey",
  "name": "live-markdown",
  "displayName": "LiveMarkdown",
  "description": "Live WYSIWYG markdown editor for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "icon": "assets/icon.png",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "liveMarkdown.markdownEditor",
        "displayName": "LiveMarkdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "liveMarkdown.toggleRawMarkdown",
        "title": "Toggle Raw Markdown",
        "icon": "$(code)",
        "category": "LiveMarkdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "liveMarkdown.toggleRawMarkdown",
          "when": "resourceExtname == '.md'",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "liveMarkdown.toggleRawMarkdown",
        "key": "shift+cmd+m",
        "mac": "shift+cmd+m",
        "win": "ctrl+shift+m",
        "linux": "ctrl+shift+m",
        "when": "resourceExtname == '.md'"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vscode:install": "npm run package && npx @vscode/vsce package --allow-missing-repository --no-rewrite-relative-links && rm -rf ~/.vscode/extensions/1abhishekpandey.live-markdown-0.0.1 && mkdir -p ~/.vscode/extensions/1abhishekpandey.live-markdown-0.0.1 && unzip -o live-markdown-0.0.1.vsix -d /tmp/live-markdown-vsix && cp -r /tmp/live-markdown-vsix/extension/. ~/.vscode/extensions/1abhishekpandey.live-markdown-0.0.1/ && rm -rf /tmp/live-markdown-vsix && echo 'Installed — reload VS Code: Cmd+Shift+P → Developer: Reload Window'",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.96.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.24.0",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-code-block-lowlight": "^2.11.0",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/extension-task-item": "^2.11.0",
    "@tiptap/extension-task-list": "^2.11.0",
    "@tiptap/html": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "lowlight": "^3.2.0",
    "tiptap-markdown": "^0.8.10"
  }
}
